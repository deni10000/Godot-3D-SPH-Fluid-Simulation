[sub_resource type="GDScript" id="GDScript_iuv88"]
script/source = "@tool
extends Node3D

@onready
var base = $\"../../FluidSimulation\"
var length: float
var width: float
var height: float
var box_scale: float
var wall_thickness: float = 0.1

var is_dragging: bool = false
var active_axis: Vector3 = Vector3(1, 0, 0)  # Global X-axis for right wall movement

func set_borders(new_length: float, new_height: float, new_width: float):
	length = new_length
	height = new_height
	width = new_width
	
	base.length = length / box_scale
	base.height = height / box_scale
	base.width = width / box_scale
	
	
	# Left wall (assuming along YZ plane at X=0)
	$Left.mesh.size = Vector2(width, height)
	$Left.mesh.center_offset = Vector3(0, height / 2, width / 2)
	
	# Back wall (along XY plane? Adjust based on your orientation)
	$Back.mesh.size = Vector2(length, height)
	$Back.mesh.center_offset = Vector3(length / 2, height / 2, 0)
	
	# Right wall (along YZ plane at X=length)
	$Right.mesh.size = Vector2(width, height)
	$Right.mesh.center_offset = Vector3(0, height / 2, width / 2)
	$Right.position.x = length
	
	# Down (floor, along XZ plane)
	$Down.mesh.size = Vector2(length, width)
	$Down.mesh.center_offset = Vector3(length / 2, 0, width / 2)

func _ready() -> void:
	box_scale = base.scale.x
	length = base.length * box_scale
	width = base.width * box_scale
	height = base.height * box_scale
	set_borders(length, height, width)
	
	# Create movable area for right wall if not already in scene
	_create_movable_area($Right, Vector3(wall_thickness, height, width), Vector3(0, height / 2, width / 2))

func _create_movable_area(parent: Node3D, size: Vector3, offset_local: Vector3) -> void:
	var area = Area3D.new()
	area.name = \"MovableArea\"
	var collision_shape = CollisionShape3D.new()
	collision_shape.name = \"CollisionShape\"
	var box_shape = BoxShape3D.new()
	box_shape.size = size
	collision_shape.shape = box_shape
	collision_shape.position = offset_local
	area.add_child(collision_shape)
	parent.add_child(area)
	
	# Connect input event (use dynamic connect)
	area.input_event.connect(self._on_movable_area_input_event)

var prev_point: Vector3
func _on_movable_area_input_event(camera: Camera3D, event: InputEvent, event_position: Vector3, normal: Vector3, shape_idx: int) -> void:
	if event is InputEventMouseButton and event.button_index == MOUSE_BUTTON_LEFT:
		if event.pressed:
			is_dragging = true
			var plane = Plane(Vector3(1, 0, 0), length) 
			prev_point = plane.intersects_ray(camera.global_position, camera.project_ray_normal(event.position))
			print(prev_point)
			

			
		# Release is handled in _input

func _input(event: InputEvent) -> void:
	if event is InputEventMouseButton and event.button_index == MOUSE_BUTTON_LEFT and not event.pressed:
		is_dragging = false
	
	if event is InputEventMouseMotion and is_dragging:
		var camera = get_viewport().get_camera_3d()
			
		var mouse_ray = camera.project_ray_normal(event.position)
		var camera_pos = camera.global_position
		var dir = Vector3(1, 0, 0).dot(mouse_ray) 
		var l: float
		var r: float
		if dir > 0:
			l = camera_pos.x
			r = 10000
		else:
			l = -10000
			r = camera_pos.x
		
		var delta = 0.001
		while r - l > delta:
			var md = (r + l) / 2
			var plane_1 = Plane(Vector3(1, 0, 0), md) 
			var plane_2 = Plane(Vector3(1, 0, 0), md + delta) 
			
			var point_1 = plane_1.intersects_ray(camera_pos, mouse_ray)
			var point_2 = plane_2.intersects_ray(camera_pos, mouse_ray)
			if prev_point.distance_squared_to(point_2) < prev_point.distance_squared_to(point_1):
				l = md
			else:
				r = md
		#print(mouse_pos)
		
		#print(dif)
		
		length = (l + r) / 2
		
		set_borders(length, height, width)
		
		
		
		
		
		#if camera == null:
			#return
		#
		## Current mouse screen pos
		#var current_mouse_pos = event.position
